$TTL 604800
@ IN SOA ns1.desarrollo.lab. admin.desarrollo.lab. (
        2           ; Serial
        604800      ; Refresh
        86400       ; Retry
        2419200     ; Expire
        604800 )    ; TTL mínimo
@ IN NS ns1.desarrollo.lab.
ns1 IN A 172.20.0.10
dev-web IN A 172.40.0.10
dev-db  IN A 172.40.0.20

