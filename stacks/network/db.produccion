$TTL 604800
@ IN SOA ns1.produccion.lab. admin.produccion.lab. (
        2           ; Serial
        604800      ; Refresh
        86400       ; Retry
        2419200     ; Expire
        604800 )    ; TTL mínimo
@ IN NS ns1.produccion.lab.
ns1 IN A 172.20.0.10
prod-web IN A 172.30.0.10
prod-db  IN A 172.30.0.20

